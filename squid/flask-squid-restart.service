[Unit]
Description=Squid Restart Service
After=network.target

[Service]
User=root
Group=root
WorkingDirectory=/etc/squid
Environment="PATH=%h/.local/share/mamba/envs/web_env/bin"
Environment="SQUID_RESTART_UI_HOST=127.0.0.1"
Environment="SQUID_RESTART_UI_PORT=8080"
ExecStart=%h/.local/share/mamba/envs/web_env/bin/python app.py

[Install]
WantedBy=multi-user.target
