#
# ---------- launch / kill ----------
alt - return        : open -na "Alacritty"
alt + shift - q     : yabai -m window --close

# ---------- focus movement (BSP + stack + space-wrap + stack-wrap) ----------
alt - h : yabai -m window --focus west  || yabai -m space --focus prev
alt - j : yabai -m window --focus stack.next || yabai -m window --focus stack.first || yabai -m window --focus south
alt - k : yabai -m window --focus stack.prev || yabai -m window --focus stack.last  || yabai -m window --focus north
alt - l : yabai -m window --focus east  || yabai -m space --focus next

# move / swap like i3 ── stack-aware + wrap-around
alt + shift - h : yabai -m window --warp west  || yabai -m window --swap west
alt + shift - j : yabai -m window --swap stack.next \
                  || yabai -m window --warp south \
                  || yabai -m window --swap south \
                  || yabai -m window --swap stack.first   # rotate to top
alt + shift - k : yabai -m window --swap stack.prev \
                  || yabai -m window --warp north \
                  || yabai -m window --swap north \
                  || yabai -m window --swap stack.last    # rotate to bottom
alt + shift - l : yabai -m window --warp east  || yabai -m window --swap east

# resize focused window
alt + ctrl - h : yabai -m window --resize left:-20:0  ; yabai -m window --resize right:-20:0
alt + ctrl - l : yabai -m window --resize right:20:0 ; yabai -m window --resize left:20:0
alt + ctrl - k : yabai -m window --resize top:-20:0  ; yabai -m window --resize bottom:0:-20
alt + ctrl - j : yabai -m window --resize bottom:0:20 ; yabai -m window --resize top:0:20

# ---------- layout / misc ----------
alt + shift - space : yabai -m window --toggle float
alt - e             : yabai -m window --toggle split        # flip split orientation
alt - b             : yabai -m window --insert stack        # make / add to stack
alt + shift - b     : yabai -m window --warp east || yabai -m window --toggle float && yabai -m window --toggle float

# ---------- monocle (fullscreen-tile) mode ----------
alt - m             : yabai -m space  --layout stack
alt + shift - m     : yabai -m space  --layout bsp
alt - n             : yabai -m window --focus next
alt + shift - n     : yabai -m window --focus prev

# ---------- native macOS fullscreen ----------
alt - f             : yabai -m window --toggle native-fullscreen     # green-button style (new space)
alt + ctrl - f      : yabai -m window --toggle zoom-fullscreen       # maximise within BSP tree node
alt + shift - f     : yabai -m window --toggle windowed-fullscreen   # edge-to-edge, same space
alt + ctrl - left   : yabai -m space  --focus prev
alt + ctrl - right  : yabai -m space  --focus next

# ---------- workspaces 1–10 ----------
alt - 1             : yabai -m space  --focus 1
alt - 2             : yabai -m space  --focus 2
alt - 3             : yabai -m space  --focus 3
alt - 4             : yabai -m space  --focus 4
alt - 5             : yabai -m space  --focus 5
alt - 6             : yabai -m space  --focus 6
alt - 7             : yabai -m space  --focus 7
alt - 8             : yabai -m space  --focus 8
alt - 9             : yabai -m space  --focus 9
alt - 0             : yabai -m space  --focus 10

alt + shift - 1     : yabai -m window --space 1  ; yabai -m space --focus 1
alt + shift - 2     : yabai -m window --space 2  ; yabai -m space --focus 2
alt + shift - 3     : yabai -m window --space 3  ; yabai -m space --focus 3
alt + shift - 4     : yabai -m window --space 4  ; yabai -m space --focus 4
alt + shift - 5     : yabai -m window --space 5  ; yabai -m space --focus 5
alt + shift - 6     : yabai -m window --space 6  ; yabai -m space --focus 6
alt + shift - 7     : yabai -m window --space 7  ; yabai -m space --focus 7
alt + shift - 8     : yabai -m window --space 8  ; yabai -m space --focus 8
alt + shift - 9     : yabai -m window --space 9  ; yabai -m space --focus 9
alt + shift - 0     : yabai -m window --space 10 ; yabai -m space --focus 10

